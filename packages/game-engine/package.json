{
  "name": "@secret/game-engine",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit",
    "test": "node --require ../../scripts/vitest-node-setup.cjs ../../node_modules/vitest/vitest.mjs run --pool=threads"
  },
  "dependencies": {
    "@secret/shared": "workspace:*"
  }
}
